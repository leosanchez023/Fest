
<link rel="stylesheet" href="/css/clientes.css">

<title>Cadastro de Clientes</title>

<header>
  <div class="header-inner">
    <div class="logo">
      <div class="logo-icon"><i class="fas fa-users"></i></div>
      <div>
        <h1>Cadastro de Clientes</h1>
        <small id="clientCount">0 clientes⚠️</small>
      </div>
    </div>

    <button class="btn btn-primary" onclick="openForm()">
      <i class="fas fa-plus"></i> <span class="btn-text">Novo Cliente</span>
    </button>
  </div>
</header>

<main>

  <!-- FORM -->
  <form 
    class="form-card" 
    action="{{#if cliente}}/clientes/editar/{{cliente.cliente_id}}{{else}}/clientes/criar{{/if}}" 
    id="formulariocard" 
    style="{{#if cliente}}display:block{{else}}display:none{{/if}}" 
    method="post"
  >

    <h2>
      <i class="fas fa-user-plus"></i> 
      {{#if cliente}}Editar Cliente{{else}}Novo Cliente{{/if}}
    </h2>

    <input type="hidden" name="id" value="{{cliente.cliente_id}}">

    <div class="form-grid">

      <div class="form-group full">
        <label>Nome completo *</label>
        <input id="nome" name="nome" value="{{cliente.nome}}" placeholder="Digite o nome completo">
      </div>

      <div class="form-group">
        <label>CPF *</label>
        <input id="cpf" name="cpf" value="{{cliente.cpf}}" placeholder="000.000.000-00" maxlength="14">
      </div>

      <div class="form-group">
        <label>Email *</label>
        <input id="email" name="email" type="email" value="{{cliente.email}}" placeholder="email@exemplo.com">
      </div>

      <div class="form-group">
        <label>Telefone *</label>
        <input id="telefone" name="telefone" value="{{cliente.telefone}}" placeholder="(00) 00000-0000">
      </div>

      <div class="form-group">
        <label>Data de nascimento</label>
        <input id="nascimento" name="nascimento" type="date" value="{{cliente.nascimento}}">
      </div>

      <div class="form-group full">
        <label>Rua</label>
        <input id="rua" name="rua" value="{{cliente.rua}}" placeholder="Nome da rua">
      </div>

      <div class="form-group">
        <label>Número</label>
        <input id="numero" name="numero" value="{{cliente.numero}}" placeholder="Nº">
      </div>

      <div class="form-group">
        <label>Cidade</label>
        <input id="cidade" name="cidade" value="{{cliente.cidade}}" placeholder="Cidade">
      </div>

      <div class="form-group">
        <label>Estado</label>
        <input id="estado" name="estado" value="{{cliente.estado}}" placeholder="UF" maxlength="2">
      </div>

    </div>

    <div class="form-actions">
      <button class="btn btn-primary" type="submit">
        {{#if cliente}}Atualizar{{else}}Salvar{{/if}}
      </button>

      <a href="/clientes" class="btn btn-secondary">Cancelar</a>
    </div>

  </form>

  <!-- LISTA -->
  <div class="client-grid">
    {{#if clientes.length}}
      {{#each clientes}}
        <div class="client-card">
          <div class="client-header">
            <h3>👤 {{this.nome}}</h3>
          </div>

          <p>📧 {{this.email}}</p>
          <p>📞 {{this.telefone}}</p>
          <p>📍 {{this.rua}}, {{this.numero}} — {{this.cidade}} / {{this.estado}}</p>

          <div class="client-actions">""
            <a href="/clientes/editar/{{this.cliente_id}}" class="btn-edit">Editar</a>
            <form action="/clientes/excluir/{{this.cliente_id}}"            method="POST">
              <button type="submit">Excluir</button>
            </form>
          </div>
        </div>
      {{/each}}
    {{else}}
      <p>Nenhum cliente cadastrado.</p>
    {{/if}}
  </div>

</main>

<script src="/js/clientes.js"></script>
