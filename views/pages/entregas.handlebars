<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/pages/entregas.css">




<style>
  :root {
    --bg: #f5f7fb;
    --card: #ffffff;
    --border: #e5e9f2;
    --muted: #6b7280;
    --fg: #0f172a;
    --primary: #6d28d9;
    --primary-2: #c026d3;
    --success: #10b981;
    --warning: #f59e0b;
    --danger: #ef4444;
    --info: #3b82f6;
    --grad-primary: linear-gradient(135deg,#7c3aed,#c026d3);
    --grad-success: linear-gradient(135deg,#10b981,#34d399);
    --grad-warning: linear-gradient(135deg,#f59e0b,#f97316);
    --grad-danger: linear-gradient(135deg,#ef4444,#dc2626);
    --grad-info: linear-gradient(135deg,#3b82f6,#6366f1);
    --shadow: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
    --shadow-lg: 0 10px 25px -8px rgba(31,41,99,.18);
  }
  * { box-sizing: border-box; }
  html, body { margin:0; padding:0; background:var(--bg); color:var(--fg); font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; }
  .container { max-width: 1400px; margin: 0 auto; padding: 24px; }
  .card { background:var(--card); border:1px solid var(--border); border-radius:14px; box-shadow:var(--shadow); }
  .kpi { border-radius:14px; padding:18px; color:#fff; box-shadow:var(--shadow-lg); position:relative; overflow:hidden; }
  .kpi .icon { position:absolute; right:14px; top:14px; opacity:.25; font-size:48px; }
  .kpi h4 { margin:0 0 4px; font-size:13px; opacity:.9; font-weight:500; }
  .kpi .val { font-size:26px; font-weight:700; }
  .kpi .sub { font-size:12px; opacity:.85; margin-top:4px; }
  .g-primary{background:var(--grad-primary)} .g-success{background:var(--grad-success)}
  .g-warning{background:var(--grad-warning)} .g-danger{background:var(--grad-danger)}
  .g-info{background:var(--grad-info)}
  .g-slate{background:linear-gradient(135deg,#475569,#334155)}
  .g-teal{background:linear-gradient(135deg,#14b8a6,#0d9488)}
  .g-rose{background:linear-gradient(135deg,#f43f5e,#e11d48)}

  .badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:600; }
  .b-success{background:#dcfce7;color:#047857}
  .b-warning{background:#fef3c7;color:#92400e}
  .b-danger{background:#fee2e2;color:#b91c1c}
  .b-info{background:#dbeafe;color:#1d4ed8}
  .b-muted{background:#f1f5f9;color:#475569}
  .b-purple{background:#ede9fe;color:#6d28d9}

  table { width:100%; border-collapse:separate; border-spacing:0; }
  th, td { text-align:left; padding:12px 14px; font-size:13px; border-bottom:1px solid var(--border); }
  th { background:#f8fafc; color:#475569; font-weight:600; font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
  tr:hover td { background:#fafbff; }
  .btn { display:inline-flex; align-items:center; gap:6px; padding:7px 12px; border-radius:8px; border:1px solid var(--border); background:#fff; cursor:pointer; font-size:13px; font-weight:500; transition:.15s; }
  .btn:hover { background:#f8fafc; }
  .btn-primary { background:var(--grad-primary); color:#fff; border:none; }
  .btn-primary:hover { filter:brightness(1.08); }
  .btn-ghost { background:transparent; border:none; padding:6px; border-radius:8px; }
  .btn-ghost:hover { background:#f1f5f9; }
  input, select { padding:8px 12px; border:1px solid var(--border); border-radius:8px; font-size:13px; background:#fff; outline:none; width:100%; }
  input:focus, select:focus { border-color:var(--primary); box-shadow:0 0 0 3px rgba(124,58,237,.12); }
  label { font-size:12px; color:var(--muted); font-weight:500; display:block; margin-bottom:4px; }

  /* Modal */
  .modal-overlay { position:fixed; inset:0; background:rgba(15,23,42,.55); display:none; align-items:flex-start; justify-content:center; z-index:50; overflow-y:auto; padding:40px 20px; }
  .modal-overlay.open { display:flex; }
  .modal { background:#fff; border-radius:16px; width:100%; max-width:1100px; box-shadow:0 25px 50px -12px rgba(0,0,0,.35); overflow:hidden; }
  .modal-header { padding:20px 24px; border-bottom:1px solid var(--border); display:flex; justify-content:space-between; align-items:center; background:var(--grad-primary); color:#fff; }
  .modal-body { padding:24px; max-height:75vh; overflow-y:auto; }

  /* Tabs */
  .tabs { display:flex; gap:4px; border-bottom:1px solid var(--border); margin-bottom:20px; overflow-x:auto; }
  .tab { padding:10px 16px; cursor:pointer; font-size:13px; font-weight:500; color:var(--muted); border-bottom:2px solid transparent; white-space:nowrap; }
  .tab.active { color:var(--primary); border-color:var(--primary); }
  .tab-panel { display:none; }
  .tab-panel.active { display:block; }

  /* Timeline */
  .timeline { display:flex; flex-direction:column; gap:0; }
  .tl-step { display:flex; gap:14px; position:relative; padding-bottom:18px; }
  .tl-step:not(:last-child)::before { content:""; position:absolute; left:15px; top:32px; bottom:0; width:2px; background:var(--border); }
  .tl-step.done:not(:last-child)::before { background:var(--success); }
  .tl-dot { width:32px; height:32px; border-radius:50%; background:#e5e7eb; color:#9ca3af; display:flex; align-items:center; justify-content:center; flex-shrink:0; z-index:1; font-size:14px; }
  .tl-step.done .tl-dot { background:var(--success); color:#fff; }
  .tl-step.active .tl-dot { background:var(--grad-primary); color:#fff; box-shadow:0 0 0 4px rgba(124,58,237,.18); }
  .tl-content h5 { margin:4px 0 2px; font-size:14px; font-weight:600; }
  .tl-content p { margin:0; font-size:12px; color:var(--muted); }

  /* Alerts */
  .alert { display:flex; gap:12px; padding:14px; border-radius:12px; align-items:flex-start; }
  .alert i { font-size:20px; flex-shrink:0; }
  .alert .title { font-weight:600; font-size:13px; margin-bottom:2px; }
  .alert .desc { font-size:12px; opacity:.85; }
  .a-danger{background:#fef2f2; color:#991b1b; border:1px solid #fecaca;}
  .a-warning{background:#fffbeb; color:#92400e; border:1px solid #fde68a;}
  .a-info{background:#eff6ff; color:#1e40af; border:1px solid #bfdbfe;}
  .a-success{background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0;}

  .grid { display:grid; gap:16px; }
  .grid-2{grid-template-columns:repeat(2,minmax(0,1fr))}
  .grid-3{grid-template-columns:repeat(3,minmax(0,1fr))}
  .grid-4{grid-template-columns:repeat(4,minmax(0,1fr))}
  .grid-6{grid-template-columns:repeat(6,minmax(0,1fr))}
  @media (max-width: 1024px){ .grid-4,.grid-6{grid-template-columns:repeat(2,1fr)} .grid-3{grid-template-columns:1fr} }
  @media (max-width: 640px){ .grid-2,.grid-4,.grid-6{grid-template-columns:1fr} }

  .progress { height:6px; background:#e5e7eb; border-radius:999px; overflow:hidden; }
  .progress > div { height:100%; background:var(--grad-success); }

  .field-row { display:flex; flex-direction:column; gap:4px; padding:10px 0; border-bottom:1px dashed var(--border); }
  .field-row .l { font-size:11px; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); }
  .field-row .v { font-size:14px; font-weight:500; }

  h1 { font-size:24px; font-weight:700; margin:0; }
  h2 { font-size:18px; font-weight:600; margin:0 0 12px; }
  h3 { font-size:15px; font-weight:600; margin:0 0 10px; color:#334155; }
  .muted { color:var(--muted); }
</style>






<div class="container">

  <!-- Header -->
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:12px;">
    <div>
      <h1>📦 Controle de Entregas, Retiradas e Pagamentos</h1>
      <p class="muted" style="margin:4px 0 0; font-size:13px;">
        Gerencie todo o ciclo de vida das locações em um só lugar
      </p>
    </div>

    <div style="display:flex; gap:8px;">
      <button class="btn">📤 Exportar</button>
      <button class="btn-primary btn" onclick="carregarPedidos()">🔄 Atualizar</button>
    </div>
  </div>

  <!-- KPIs -->
  <div class="grid grid-4" style="margin-bottom:20px;">
    <div class="kpi g-primary" onclick="filterByKpi('active')" style="cursor:pointer;">
  <h4>Pedidos Ativos</h4>
  <div class="val" id="kpi-active">0</div>
</div>

<div class="kpi g-info" onclick="filterByKpi('delivery')" style="cursor:pointer;">
  <h4>Entregas Hoje</h4>
  <div class="val" id="kpi-delivery">0</div>
</div>

<div class="kpi g-warning" onclick="filterByKpi('pickup')" style="cursor:pointer;">
  <h4>Retiradas Hoje</h4>
  <div class="val" id="kpi-pickup">0</div>
</div>

<div class="kpi g-danger" onclick="filterByKpi('late')" style="cursor:pointer;">
  <h4>Pagamentos Atrasados</h4>
  <div class="val" id="kpi-late">0</div>
</div>
  </div>

  </div>

  <!-- ALERTAS -->
  <div class="card" style="padding:20px; margin-bottom:20px;">
    <h2>🚨 Alertas</h2>
    <div class="grid grid-3" id="alerts"></div>
  </div>

  <!-- FILTROS -->
  <div class="card" style="padding:18px; margin-bottom:20px;">
    <h2>🔎 Filtros</h2>

    <div class="grid grid-6">

      <div>
        <label>Buscar</label>
        <input id="f-search" placeholder="Cliente, pedido..." />
      </div>

      <div>
        <label>Data inicial</label>
        <input type="date" id="f-from" />
      </div>

      <div>
        <label>Data final</label>
        <input type="date" id="f-to" />
      </div>

      <!-- PAGAMENTO -->
      <div>
        <label>Pagamento⚠️</label>
        <select id="f-pay">
          <option value="">Todos</option>
          <option value="Pago Integralmente">Pago Integralmente</option>
          <option value="Parcialmente Pago">Parcialmente Pago</option>
          <option value="Não Pago">Não Pago</option>
        </select>
      </div>

      <!-- ENTREGA -->
      <div>
        <label>Entrega⚠️</label>
        <select id="f-deliv">
          <option value="">Todas</option>
          <option value="Aguardando Entrega">Aguardando Entrega</option>
          <option value="Em Rota">Em Rota</option>
          <option value="Entregue">Entregue</option>
          <option value="Entrega Atrasada">Entrega Atrasada</option>
        </select>
      </div>

      <!-- STATUS (BANCO) -->
      <div>
        <label>Status</label>
        <select id="f-status">
          <option value="">Todos</option>
          <option value="ORCAMENTO">Orçamento</option>
          <option value="CONFIRMADO">Confirmado</option>
          <option value="EM_PREPARO">Em Preparo</option>
          <option value="ENTREGUE">Entregue</option>
          <option value="RETIRADO">Retirado</option>
          <option value="FINALIZADO">Finalizado</option>
          <option value="CANCELADO">Cancelado</option>
        </select>
      </div>

    </div>
  </div>

  <!-- TABELA -->
  <div class="card">
    <div style="padding:18px; display:flex; justify-content:space-between;">
      <h2>📋 Pedidos</h2>
      <span id="count-badge">0 pedidos</span>
    </div>

    <div style="overflow-x:auto;">
      <table>
        <thead>
          <tr>
            <th>Pedido</th>
            <th>Cliente</th>
            <th>Evento</th>
            <th>Entrega</th>
            <th>Retirada</th>
            <th>Total</th>
            <th>Pago</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="orders-tbody"></tbody>
      </table>
    </div>
  </div>

</div>

<!-- MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">

    <div class="modal-header">
      <div>
        <div id="m-id">PED-0000</div>
        <div id="m-customer">Cliente</div>
        <div id="m-status" class="muted" style="margin-top:8px;"></div>
      </div>
      <button onclick="closeModal()">✖</button>
    </div>

    <div class="modal-body">
      <div id="m-timeline"></div>

      <div class="tabs">
        <div class="tab active" data-tab="dados">📄 Dados</div>
        <div class="tab" data-tab="fin">💰 Financeiro</div>
        <div class="tab" data-tab="log">🚚 Logística</div>
        <div class="tab" data-tab="dev">🔄 Devolução</div>
        <div class="tab" data-tab="oco">⚠️ Ocorrências</div>
      </div>

      <div class="tab-panel active" id="tab-dados"><div id="m-dados"></div></div>
      <div class="tab-panel" id="tab-fin"><div id="m-fin"></div></div>
      <div class="tab-panel" id="tab-log"><div id="m-log"></div></div>
      <div class="tab-panel" id="tab-dev"><div id="m-dev"></div></div>
      <div class="tab-panel" id="tab-oco"><div id="m-oco"></div></div>

    </div>
  </div>
</div>

<script src="/js/entregas.js"></script>